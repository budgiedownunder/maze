
@startuml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Architecture Diagram for Maze Project

Person(user, "User", "A user of the system")

Container(auth, "auth", "Rust", "Authentication library")
Container(browser, "Browser", "", "Internet browser")
Container(maze_maui_app_net, "Maze.Maui.App", "C#", ".NET maze application (MAUI)")
Container(maze_console, "maze_console", "Rust", "Console application")
Container(api, "API", "", ".NET, JavaScript, Rust, Web")
Container(maze_wasm, "maze_wasm", "Rust", "WebAssembly API")
Container(maze_web_server, "maze_web_server", "Rust", "Console application")
Container(storage, "storage", "Rust", "Data storage")

Rel(user, browser, "Uses")
Rel(user, maze_maui_app_net, "Uses")
Rel(user, maze_console, "Uses")
Rel(browser, api, "")
Rel(maze_maui_app_net, api, "")
Rel(maze_console, api, "")
Rel(api, maze_wasm, "")
Rel(api, maze_web_server, "")
Rel(maze_web_server, maze_wasm, "")
Rel(maze_web_server, auth, "")
Rel(maze_web_server, storage, "")

@enduml