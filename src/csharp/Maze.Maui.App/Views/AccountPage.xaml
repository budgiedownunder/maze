<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
             x:DataType="viewmodel:AccountViewModel"
             x:Class="Maze.Maui.App.Views.AccountPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid VerticalOptions="FillAndExpand"
          HorizontalOptions="FillAndExpand">

        <ScrollView VerticalOptions="FillAndExpand">
            <VerticalStackLayout Padding="30"
                                 Spacing="16"
                                 MinimumWidthRequest="280"
                                 HorizontalOptions="Center">

                <Label Text="{Binding LoadStatus}"
                       IsVisible="{Binding IsBusy}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <Border Padding="16"
                        Margin="0,0,0,8"
                        IsVisible="{Binding IsNotBusy}">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto,Auto"
                              ColumnSpacing="12"
                              RowSpacing="12">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Username"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Username}"
                                   Keyboard="Text"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="Full Name"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="1" Grid.Column="1"
                                   Text="{Binding FullName}"
                                   Keyboard="Text"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center" />

                            <Label Grid.Row="2" Grid.Column="0"
                                   Text="Email"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center" />
                            <Entry Grid.Row="2" Grid.Column="1"
                                   Text="{Binding Email}"
                                   Keyboard="Email"
                                   HorizontalOptions="Fill"
                                   VerticalOptions="Center" />
                        </Grid>

                        <Label Text="Administrator"
                               IsVisible="{Binding IsAdmin}"
                               TextColor="White"
                               BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                               Padding="8,4"
                               HorizontalOptions="Start" />

                    </VerticalStackLayout>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Save Profile"
                        Command="{Binding SaveProfileCommand}"
                        IsVisible="{Binding IsNotBusy}"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Change Password"
                        Command="{Binding ChangePasswordCommand}"
                        IsVisible="{Binding IsNotBusy}"
                        HorizontalOptions="FillAndExpand"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <Button Text="Sign Out"
                        Command="{Binding SignOutCommand}"
                        IsVisible="{Binding IsNotBusy}"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Delete Account"
                        Command="{Binding DeleteAccountCommand}"
                        IsVisible="{Binding IsNotBusy}"
                        HorizontalOptions="FillAndExpand"
                        BackgroundColor="Red"
                        TextColor="White" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="FillAndExpand"
                           VerticalOptions="CenterAndExpand" />

    </Grid>

</ContentPage>
