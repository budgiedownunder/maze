<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
               x:DataType="viewmodel:AccountViewModel"
               x:Class="Maze.Maui.App.Views.AccountPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <toolkit:Popup.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
    </toolkit:Popup.Resources>

    <Border Padding="16"
            StrokeShape="RoundRectangle 8"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

        <Grid VerticalOptions="Fill"
              HorizontalOptions="Fill">

            <ScrollView VerticalOptions="Fill">
                <VerticalStackLayout Spacing="16"
                                     HorizontalOptions="Fill">

                    <!-- Title -->
                    <Label Text="My Account"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           Margin="0,0,0,4" />

                    <!-- Welcome banner shown only when the popup was auto-opened
                         after a brand-new OAuth sign-up. Cleared on popup dismiss. -->
                    <Border IsVisible="{Binding IsWelcomeMode}"
                            Padding="10,8"
                            StrokeShape="RoundRectangle 4"
                            Stroke="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                            StrokeThickness="1"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Secondary}, Dark={StaticResource Gray600}}">
                        <Label Text="Welcome to Maze! Take a moment to set your username and full name."
                               LineBreakMode="WordWrap"
                               TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
                    </Border>

                    <Label Text="{Binding LoadStatus}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

                    <Border Padding="16"
                            Margin="0,0,0,8"
                            IsVisible="{Binding IsNotBusy}">
                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="Auto,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="12"
                                  RowSpacing="12">
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="Username"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Entry Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Username}"
                                       Keyboard="Text"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Center" />

                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="Full Name"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center" />
                                <Entry Grid.Row="1" Grid.Column="1"
                                       Text="{Binding FullName}"
                                       Keyboard="Text"
                                       HorizontalOptions="Fill"
                                       VerticalOptions="Center" />
                            </Grid>

                            <Label Text="Administrator"
                                   IsVisible="{Binding IsAdmin}"
                                   TextColor="White"
                                   BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                                   Padding="8,4"
                                   HorizontalOptions="Start" />

                        </VerticalStackLayout>
                    </Border>

                    <Label Text="{Binding ErrorMessage}"
                           TextColor="Red"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                           HorizontalOptions="Center" />

                    <Button Text="Save Profile"
                            Command="{Binding SaveProfileCommand}"
                            IsVisible="{Binding IsNotBusy}"
                            HorizontalOptions="Fill" />

                    <Button Text="Change Password"
                            Command="{Binding ChangePasswordCommand}"
                            IsVisible="{Binding IsNotBusy}"
                            HorizontalOptions="Fill"
                            BackgroundColor="Transparent"
                            TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}">
                        <!-- Trigger flips the label for OAuth-only users (no
                             password yet). The Set/Change semantics live in
                             ChangePasswordViewModel; this just reflects the
                             current `HasPassword` state on the trigger. -->
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding HasPassword}" Value="False">
                                <Setter Property="Text" Value="Set Password" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Text="Delete Account"
                            Command="{Binding DeleteAccountCommand}"
                            IsVisible="{Binding IsNotBusy}"
                            HorizontalOptions="Fill"
                            BackgroundColor="Red"
                            TextColor="White" />

                    <Button Text="Close"
                            Clicked="OnCloseClicked"
                            IsVisible="{Binding IsNotBusy}"
                            HorizontalOptions="Fill"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

                </VerticalStackLayout>
            </ScrollView>

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               HorizontalOptions="Fill"
                               VerticalOptions="Center" />

        </Grid>

    </Border>

</toolkit:Popup>
