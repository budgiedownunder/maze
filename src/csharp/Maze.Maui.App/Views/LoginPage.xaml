<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
             x:DataType="viewmodel:LoginViewModel"
             x:Class="Maze.Maui.App.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertBoolConverter" />
    </ContentPage.Resources>

    <Grid VerticalOptions="Fill"
          HorizontalOptions="Fill">

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="30"
                                 Spacing="16"
                                 MaximumWidthRequest="400"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Border HeightRequest="100"
                        WidthRequest="100"
                        StrokeShape="Ellipse"
                        Padding="0"
                        HorizontalOptions="Center">
                    <Image Source="app.png"
                           Aspect="AspectFill"
                           HeightRequest="100"
                           WidthRequest="100" />
                </Border>

                <Label Text="Maze"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="Sign in to your account"
                       FontSize="16"
                       HorizontalOptions="Center"
                       Margin="0,0,0,16" />

                <Grid ColumnSpacing="8" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Username"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="0" Grid.Column="1"
                           Text="{Binding Username}"
                           ReturnType="Next"
                           Keyboard="Plain"
                           MinimumWidthRequest="150" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="1" Grid.Column="1"
                           Text="{Binding Password}"
                           IsPassword="{Binding ShowPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Go"
                           ReturnCommand="{Binding SignInCommand}"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="1" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Sign In"
                        Command="{Binding SignInCommand}"
                        HorizontalOptions="Fill" />

                <Button Text="Sign Up"
                        Command="{Binding GoToSignUpCommand}"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
