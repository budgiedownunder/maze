<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
             x:DataType="viewmodel:LoginViewModel"
             x:Class="Maze.Maui.App.Views.LoginPage"
             Shell.NavBarIsVisible="False"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
    </ContentPage.Resources>

    <Grid VerticalOptions="FillAndExpand"
          HorizontalOptions="FillAndExpand">

        <ScrollView VerticalOptions="CenterAndExpand">
            <VerticalStackLayout Padding="30"
                                 Spacing="16"
                                 MaximumWidthRequest="400"
                                 HorizontalOptions="Center"
                                 VerticalOptions="CenterAndExpand">

                <Border HeightRequest="100"
                        WidthRequest="100"
                        StrokeShape="Ellipse"
                        Padding="0"
                        HorizontalOptions="Center">
                    <Image Source="app.png"
                           Aspect="AspectFill"
                           HeightRequest="100"
                           WidthRequest="100" />
                </Border>

                <Label Text="Maze"
                       FontSize="36"
                       FontAttributes="Bold"
                       HorizontalOptions="Center" />

                <Label Text="Sign in to your account"
                       FontSize="16"
                       HorizontalOptions="Center"
                       Margin="0,0,0,16" />

                <Entry Placeholder="Username"
                       Text="{Binding Username}"
                       ReturnType="Next"
                       Keyboard="Text" />

                <Entry Placeholder="Password"
                       Text="{Binding Password}"
                       IsPassword="True"
                       ReturnType="Go"
                       ReturnCommand="{Binding SignInCommand}" />

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Sign In"
                        Command="{Binding SignInCommand}"
                        HorizontalOptions="FillAndExpand" />

                <Button Text="Sign Up"
                        Command="{Binding GoToSignUpCommand}"
                        HorizontalOptions="FillAndExpand"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="FillAndExpand"
                           VerticalOptions="CenterAndExpand" />

    </Grid>

</ContentPage>
