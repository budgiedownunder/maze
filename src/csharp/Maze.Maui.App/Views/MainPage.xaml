<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:Maze.Maui.App.Controls"
             x:Class="Maze.Maui.App.Views.MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="70" />
        </Grid.RowDefinitions>

        <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Horizontal" HorizontalOptions="Start" Padding="10,10" Spacing="10">
            <Button
                x:Name="CounterBtn"
                Text="Click me" 
                HeightRequest="40"
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />
            <Button
                x:Name="ResetBtn"
                Text="Reset" 
                HeightRequest="30"
                SemanticProperties.Hint="Resets the maze"
                Clicked="OnResetBtn_Clicked"
                HorizontalOptions="Fill" />
        </StackLayout>

        <Grid Grid.Row="1" Grid.Column="0">
            <ScrollView x:Name="MazeGridScrollView" 
                Orientation="Both"
                Padding="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                HorizontalScrollBarVisibility="Always"
                VerticalScrollBarVisibility="Always">

                <controls:MazeGrid x:Name="MazeGrid" 
                                ContainerScrollView="{Binding Source={x:Reference MazeGridScrollView}}" 
                                RowSpacing="0" 
                                ColumnSpacing="0" 
                                Padding="10"
                                HorizontalOptions="Start"
                                VerticalOptions="Start">
                </controls:MazeGrid>
            </ScrollView>
        </Grid>

        <StackLayout Grid.Row="2" Grid.Column="0"  Orientation="Horizontal" HorizontalOptions="Start" Padding="10,10" Spacing="10">
            <Button
                x:Name="CounterBtn2"
                Text="Click me" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />
            <Button
                x:Name="ResetBtn2"
                Text="Reset" 
                SemanticProperties.Hint="Resets the maze"
                Clicked="OnResetBtn_Clicked"
                HorizontalOptions="Fill" />
        </StackLayout>

    </Grid>
</ContentPage>
