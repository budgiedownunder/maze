<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Maze.Maui.App.Views.ConfirmationPopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border Padding="20"
            StrokeShape="RoundRectangle 8"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

        <VerticalStackLayout Spacing="16" MinimumWidthRequest="320">

            <!-- Title -->
            <Label x:Name="TitleLabel"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,4" />

            <!-- Message -->
            <Label x:Name="MessageLabel"
                   FontSize="14"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" />

            <!-- Buttons -->
            <Grid x:Name="ButtonRow" ColumnDefinitions="*,*,*" ColumnSpacing="8">

                <Button Grid.Column="0"
                        x:Name="DismissButton"
                        Clicked="OnDismissClicked"
                        HorizontalOptions="Fill"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                        TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

                <Button Grid.Column="1"
                        x:Name="CancelButton"
                        Clicked="OnCancelClicked"
                        HorizontalOptions="Fill"
                        BackgroundColor="Red"
                        TextColor="White" />

                <Button Grid.Column="2"
                        x:Name="AcceptButton"
                        Clicked="OnAcceptClicked"
                        HorizontalOptions="Fill" />

            </Grid>

        </VerticalStackLayout>

    </Border>

</toolkit:Popup>
