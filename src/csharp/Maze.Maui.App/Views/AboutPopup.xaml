<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Maze.Maui.App.Views.AboutPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <VerticalStackLayout Spacing="12" HorizontalOptions="Fill" Padding="16">

        <Border HeightRequest="100"
                WidthRequest="100"
                StrokeShape="Ellipse"
                Padding="0"
                HorizontalOptions="Center">
            <Image Source="app.png"
                   Aspect="AspectFill"
                   HeightRequest="100"
                   WidthRequest="100"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>
        <Label FontSize="16"
               FontAttributes="Bold"
               Text="Maze Application v1.0"
               LineBreakMode="WordWrap"
               HorizontalOptions="Center" />
        <Label FontSize="14"
               FontAttributes="None"
               Text="© BudgieDownUnder, 2026"
               HorizontalOptions="Center" />

        <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" />
        <Label Text="An app for designing and solving mazes"
               HorizontalOptions="Center" />

        <Button Text="Close"
                Clicked="OnCloseClicked"
                HorizontalOptions="Fill"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

    </VerticalStackLayout>

</toolkit:Popup>
