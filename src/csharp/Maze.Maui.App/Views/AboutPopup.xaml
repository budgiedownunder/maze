<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Maze.Maui.App.Views.AboutPopup"
               CanBeDismissedByTappingOutsideOfPopup="True">

    <Grid RowDefinitions="Auto, Auto"
          Padding="16"
          BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12" HorizontalOptions="Fill">

                <Border HeightRequest="64"
                        WidthRequest="64"
                        StrokeShape="Ellipse"
                        Padding="0"
                        HorizontalOptions="Center">
                    <Image Source="app.png"
                           Aspect="AspectFill"
                           HeightRequest="64"
                           WidthRequest="64"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label FontSize="16"
                       FontAttributes="Bold"
                       Text="Maze Application v1.0"
                       LineBreakMode="WordWrap"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
                <Label FontSize="14"
                       FontAttributes="None"
                       Text="© BudgieDownUnder, 2026"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

                <BoxView HeightRequest="1"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}"
                         HorizontalOptions="Fill" />
                <Label Text="An app for designing and solving mazes"
                       HorizontalOptions="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="1"
                Text="Close"
                Clicked="OnCloseClicked"
                Margin="0,12,0,0"
                HorizontalOptions="Fill"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />

    </Grid>

</toolkit:Popup>
