<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
             x:DataType="viewmodel:ChangePasswordViewModel"
             x:Class="Maze.Maui.App.Views.ChangePasswordPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertBoolConverter" />
    </ContentPage.Resources>

    <Grid VerticalOptions="Fill"
          HorizontalOptions="Fill">

        <ScrollView VerticalOptions="Fill">
            <VerticalStackLayout Padding="30"
                                 Spacing="16"
                                 MaximumWidthRequest="400"
                                 HorizontalOptions="Center">

                <Grid ColumnSpacing="8" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Current Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="0" Grid.Column="1"
                           Text="{Binding CurrentPassword}"
                           IsPassword="{Binding ShowCurrentPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Next"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="0" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowCurrentPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowCurrentPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="New Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="1" Grid.Column="1"
                           Text="{Binding NewPassword}"
                           IsPassword="{Binding ShowNewPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Next"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="1" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowNewPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowNewPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Confirm New Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="2" Grid.Column="1"
                           Text="{Binding ConfirmNewPassword}"
                           IsPassword="{Binding ShowConfirmNewPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Go"
                           ReturnCommand="{Binding ChangePasswordCommand}"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="2" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowConfirmNewPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowConfirmNewPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Change Password"
                        Command="{Binding ChangePasswordCommand}"
                        HorizontalOptions="Fill" />

                <Button Text="Back"
                        Command="{Binding GoBackCommand}"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
