<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:Maze.Maui.App.ViewModels"
             xmlns:services="clr-namespace:Maze.Maui.App.Services"
             xmlns:converters="clr-namespace:Maze.Maui.App.Converters"
             x:DataType="viewmodel:SignUpViewModel"
             x:Class="Maze.Maui.App.Views.SignUpPage"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <toolkit:IsStringNotNullOrEmptyConverter x:Key="StringNotEmptyConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertBoolConverter" />
        <converters:OAuthProviderIconConverter x:Key="OAuthIconConverter" />
    </ContentPage.Resources>

    <Grid VerticalOptions="Fill"
          HorizontalOptions="Fill">

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Padding="30"
                                 Spacing="16"
                                 MaximumWidthRequest="400"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Border HeightRequest="100"
                        WidthRequest="100"
                        StrokeShape="Ellipse"
                        Padding="0"
                        HorizontalOptions="Center">
                    <Image Source="app.png"
                           Aspect="AspectFill"
                           HeightRequest="100"
                           WidthRequest="100" />
                </Border>

                <Grid ColumnSpacing="8" RowSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0"
                           Text="Email"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="0" Grid.Column="1"
                           Text="{Binding Email}"
                           ReturnType="Next"
                           Keyboard="Email"
                           MinimumWidthRequest="150" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Text="Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="1" Grid.Column="1"
                           Text="{Binding Password}"
                           IsPassword="{Binding ShowPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Next"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="1" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>

                    <Label Grid.Row="2" Grid.Column="0"
                           Text="Confirm Password"
                           VerticalOptions="Center" />
                    <Entry Grid.Row="2" Grid.Column="1"
                           Text="{Binding ConfirmPassword}"
                           IsPassword="{Binding ShowConfirmPassword, Converter={StaticResource InvertBoolConverter}}"
                           ReturnType="Go"
                           ReturnCommand="{Binding SignUpCommand}"
                           MinimumWidthRequest="150" />
                    <ImageButton Grid.Row="2" Grid.Column="2"
                                 Source="icon_show_password.png"
                                 Command="{Binding ToggleShowConfirmPasswordCommand}"
                                 BackgroundColor="Transparent"
                                 HeightRequest="32"
                                 WidthRequest="32"
                                 Padding="4"
                                 VerticalOptions="Center">
                        <ImageButton.Triggers>
                            <DataTrigger TargetType="ImageButton"
                                         Binding="{Binding ShowConfirmPassword}"
                                         Value="True">
                                <Setter Property="Source" Value="icon_hide_password.png" />
                            </DataTrigger>
                        </ImageButton.Triggers>
                    </ImageButton>
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyConverter}}"
                       HorizontalOptions="Center" />

                <Button Text="Sign Up"
                        Command="{Binding SignUpCommand}"
                        HorizontalOptions="Fill" />

                <Button Text="Back"
                        Command="{Binding GoBackCommand}"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent"
                        TextColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}" />

                <!-- OAuth providers (server-driven). Hidden when none are configured. -->
                <VerticalStackLayout Spacing="8"
                                     IsVisible="{Binding HasOAuthProviders}">
                    <Label Text="or"
                           HorizontalOptions="Center"
                           TextColor="Gray" />
                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding OAuthProviders}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:OAuthProviderPublic">
                                <Button Text="{Binding DisplayName, StringFormat='Continue with {0}'}"
                                        ImageSource="{Binding Name, Converter={StaticResource OAuthIconConverter}}"
                                        ContentLayout="Left,8"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:SignUpViewModel}}, Path=SignInWithOAuthCommand}"
                                        CommandParameter="{Binding Name}"
                                        HorizontalOptions="Fill"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                                        TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark={StaticResource White}}"
                                        BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                        BorderWidth="1" />
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <ActivityIndicator IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           HorizontalOptions="Fill"
                           VerticalOptions="Center" />

    </Grid>

</ContentPage>
