<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               x:Class="Maze.Maui.App.Views.GameResultPopup"
               CanBeDismissedByTappingOutsideOfPopup="False">

    <Border Padding="24"
            StrokeShape="RoundRectangle 12"
            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}"
            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}">

        <VerticalStackLayout Spacing="16" HorizontalOptions="Center" MinimumWidthRequest="260">

            <Image x:Name="CelebrationImage"
                   Source="celebrate.gif"
                   WidthRequest="200"
                   HeightRequest="200"
                   IsAnimationPlaying="True"
                   HorizontalOptions="Center" />

            <Label x:Name="MessageLabel"
                   FontSize="16"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />

            <BoxView HeightRequest="1" BackgroundColor="Gray" HorizontalOptions="Fill" />

            <Button Text="Close"
                    HorizontalOptions="Center"
                    MinimumWidthRequest="100"
                    Clicked="OnCloseClicked" />

        </VerticalStackLayout>

    </Border>

</toolkit:Popup>
