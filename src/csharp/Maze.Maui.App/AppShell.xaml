<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Maze.Maui.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Maze.Maui.App.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Unauthenticated: Login page, tab bar and nav bar hidden -->
    <TabBar x:Name="LoginTabBar">
        <ShellContent
            Route="LoginPage"
            Shell.TabBarIsVisible="False"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:LoginPage}" />
    </TabBar>

    <!-- Authenticated: main app tabs -->
    <TabBar x:Name="MainTabBar">
        <ShellContent
            Title="Mazes"
            Route="MainPage"
            Icon="{OnPlatform 'icon_mazes.png', iOS='icon_mazes_ios.png', MacCatalyst='icon_mazes_ios.png'}"
            ContentTemplate="{DataTemplate views:MazesPage}" />
        <ShellContent
            Title="Account"
            Route="AccountPage"
            Icon="icon_account.svg"
            ContentTemplate="{DataTemplate views:AccountPage}" />
        <ShellContent
            Title="About"
            Route="AboutPage"
            Icon="{OnPlatform 'icon_about.png', iOS='icon_about_ios.png', MacCatalyst='icon_about_ios.png'}"
            ContentTemplate="{DataTemplate views:AboutPage}" />
    </TabBar>

</Shell>
