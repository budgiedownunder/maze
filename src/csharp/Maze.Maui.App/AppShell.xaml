<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Maze.Maui.App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Maze.Maui.App.Views"
    FlyoutBehavior="Flyout">

    <!-- Unauthenticated: Login page, tab bar, nav bar, and flyout all hidden -->
    <TabBar x:Name="LoginTabBar" Shell.FlyoutBehavior="Disabled">
        <ShellContent
            Route="LoginPage"
            Shell.TabBarIsVisible="False"
            Shell.NavBarIsVisible="False"
            ContentTemplate="{DataTemplate views:LoginPage}" />
    </TabBar>

    <!-- Authenticated: Mazes page only (single tab, tab bar hidden) -->
    <TabBar x:Name="MainTabBar">
        <ShellContent
            Title="Mazes"
            Route="MainPage"
            Shell.TabBarIsVisible="False"
            ContentTemplate="{DataTemplate views:MazesPage}" />
    </TabBar>

    <!-- Flyout menu items -->
    <MenuItem Text="My Account..."
              IconImageSource="{OnPlatform 'icon_account.png', iOS='icon_account_ios.png', MacCatalyst='icon_account_ios.png'}"
              Clicked="OnAccountMenuItemClicked" />
    <MenuItem Text="Sign Out"
              Clicked="OnSignOutMenuItemClicked" />
    <MenuItem Text="About"
              IconImageSource="{OnPlatform 'icon_about.png', iOS='icon_about_ios.png', MacCatalyst='icon_about_ios.png'}"
              Clicked="OnAboutMenuItemClicked" />

</Shell>
