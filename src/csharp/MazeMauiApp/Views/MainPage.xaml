<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:MazeMauiApp.Controls"
             x:Class="MazeMauiApp.Views.MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackLayout Grid.Row="0" Orientation="Horizontal" HorizontalOptions="Start" Padding="10,10" Spacing="10">
            <Button
                x:Name="CounterBtn"
                Text="Click me" 
                SemanticProperties.Hint="Counts the number of times you click"
                Clicked="OnCounterClicked"
                HorizontalOptions="Fill" />
            <Button
                x:Name="ResetBtn"
                Text="Reset" 
                SemanticProperties.Hint="Resets the maze"
                Clicked="OnResetBtn_Clicked"
                HorizontalOptions="Fill" />
        </StackLayout>

        <ScrollView x:Name="MazeGridScrollView" Grid.Row ="1"  Orientation="Both" Padding="0" HorizontalScrollBarVisibility="Always" VerticalScrollBarVisibility="Always">
            <controls:MazeGrid x:Name="MazeGrid" ContainerScrollView="{Binding Source={x:Reference MazeGridScrollView}}" RowSpacing="0" ColumnSpacing="0">
            </controls:MazeGrid>
        </ScrollView>

    </Grid>
</ContentPage>
