{
  "metadata": [
    {
      "src": [
        {
          "files": [ "Maze.Wasm.Interop.csproj" ],
          "exclude": [ "bin/**/*", "obj/**/*, docx/**/*" ]
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docx/articles/**.md",
          "docx/articles/**/toc.yml",
          "toc.yml",
          "docx/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "docx/images/**"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "docx/apidoc/**.md"
        ],
        "exclude": [
          "docx/obj/**",
          "docx/_site/**"
        ]
      }
    ],
    "xref": [
      "no"
    ],
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}