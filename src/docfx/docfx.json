{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "**/Maze.Api/bin/Debug/net10.0/Maze.Api.dll",
            "**/Maze.Api.Tests/bin/Debug/net10.0/win-x64/Maze.Api.Tests.dll",
            "**/Maze.Maui.App/bin/Debug/net10.0-windows10.0.19041.0/win-x64/Maze.Maui.App.dll",
            "**/Maze.Maui.Controls/bin/Debug/net10.0-windows10.0.19041.0/win-x64/Maze.Maui.Controls.dll",
            "**/Maze.Maui.Services/bin/Debug/net10.0-windows10.0.19041.0/win-x64/Maze.Maui.Services.dll",
            "**/Maze.Interop/bin/Debug/net10.0/win-x64/Maze.Interop.dll",
            "**/Maze.Interop.Tests/bin/Debug/net10.0/win-x64/Maze.Interop.Tests.dll"
          ],  
          "exclude": [ 
            "bin/**/*", 
            "obj/**/*", 
            "**/*.csproj",
            "**/__XamlGeneratedCode__*.yml",
            "**/__XamlGeneratedCode__*"            
          ],
           "src": "../csharp"
        }
      ],
      "dest": "api/net",
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "properties": {
        "ExcludeMobileFrameworks": "true",
        "IsBuildingHelp": "true",
        "Configuration": "Debug",
        "TargetFramework": "net10.0-windows10.0.19041.0"
      },
      "filter": "filter.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/net/**.yml",
          "api/net/index.md",
          "api/net/Maze.Maui.Controls.md",
          "api/rust/**.md",
          "api/js/**.md",
          "api/wasm/**.md",
          "api/web/**.md"
        ],
        "exclude": [
          "**/__XamlGeneratedCode__*.yml"
        ]        
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "api/**/toc.yml",
          "toc.yml",
          "*.md" 
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "styles/main.css"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "./_site",
    "homepage": "index.md",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "globalMetaData": {
      "_appTitle": "Maze Project Documentation",
      "_appName": "maze",
      "_appLogoPath": "images/logo.png",
      "_appFooter": "Generated by <strong>DocFX</strong>",
      "_enableSearch": false,
      "_disableContribution": true
    },
    "styles": [
      "styles/main.css"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}