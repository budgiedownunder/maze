{
  "metadata": [
    {
      "src": [
        {
          "files": [ "**/*.csproj" ],
          "exclude": [ "bin/**/*", "obj/**/*" ],
          "src": "../csharp"
        }
      ],
      "dest": "api/net",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/net/**.yml",
          "api/net/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md" 
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "styles/main.css"
        ]
      }
    ],
    "overwrite": [
      {
        "files": [
          "apidoc/**.md"
        ],
        "exclude": [
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "dest": "./_site",
    "homepage": "index.md",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default"
    ],
    "globalMetaData": {
      "_appTitle": "Maze Project Documentation",
      "_appName": "maze-project",
      "_appLogoPath": "images/logo.png",
      "_appFooter": "Generated by <strong>DocFX</strong>",
      "_enableSearch": false,
      "_disableContribution": true
    },
    "styles": [
      "styles/main.css"
    ],
    "postProcessors": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}