@startuml

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Container diagram for Maze Project

Person(user, "User", "A user of the system")
System_Boundary(c1, "Maze Project") {
    Container(cli_app, "Maze CLI", "Rust", "Command-line application ")
    Container(maze_library, "Maze", "Rust", "Provides maze definition and solution calculation functionality")
}

Rel(user, cli_app, "Uses")
Rel(cli_app, maze_library, "Uses")
@enduml